function pyramid(char, rows, inverted) {
  let result = "\n";

  if (!inverted) {
    // Pyramid pointing up
    for (let i = 0; i < rows; i++) {
      result += " ".repeat(rows - i - 1);
      result += char.repeat(i * 2 + 1);
      result += "\n";
    }
  } else {
    // Pyramid pointing down
    for (let i = rows - 1; i >= 0; i--) {
      result += " ".repeat(rows - i - 1);
      result += char.repeat(i * 2 + 1);
      result += "\n";
    }
  }

  return result;
}